<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aijia.aijia.mapper.UnitMapper">

    <select id="selectUnitPage" resultType="com.aijia.aijia.entity.vo.UnitVO">
        SELECT
        u.*,
        b.name as building_name
        FROM bus_unit u
        LEFT JOIN bus_building b ON u.building_id = b.id
        <where>
            u.is_deleted = 0
            <if test="ew != null">
                <if test="ew.emptyOfWhere == false">
                    AND ${ew.sqlSegment}
                </if>
            </if>
        </where>
    </select>
</mapper>
